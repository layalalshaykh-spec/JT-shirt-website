# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=4000
NODE_ENV=development

# Auth: secret used to sign admin JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Admin login. The admin panel (/admin.html) requires this password.
ADMIN_PASSWORD=admin123

# Free shipping threshold and flat shipping rate (in dollars).
# B2B orders are large, so the threshold is higher than a retail store.
FREE_SHIPPING_THRESHOLD=500
SHIPPING_FLAT_RATE=24.99

# Sales tax rate (as a decimal, e.g. 0.08 for 8 percent)
TAX_RATE=0.08

# Payments (optional). Mock checkout is used when this is empty.
# To go live later, add your Stripe secret key and wire it in server/routes/orders.js.
STRIPE_SECRET_KEY=
